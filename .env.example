# MathGameApp Environment Configuration
# Copy this file to .env and update with your actual credentials

# Server Configuration
PORT=3000
NODE_ENV=development
SESSION_SECRET=mathgame-secret-key-change-in-production

# Database Configuration
# Options: 'mysql', 'azuresql', or 'sqlserver'
DB_TYPE=azuresql

# Azure SQL Database Configuration (if DB_TYPE=azuresql)
AZURE_SQL_SERVER=your-server-name.database.windows.net
AZURE_SQL_DATABASE=mathgameapp
AZURE_SQL_USER=your-admin-username
AZURE_SQL_PASSWORD=your-secure-password
AZURE_SQL_PORT=1433
AZURE_SQL_ENCRYPT=true
AZURE_SQL_TRUST_SERVER_CERTIFICATE=false

# MySQL Configuration (if DB_TYPE=mysql)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=yourpassword
MYSQL_DATABASE=mathgameapp

# Local SQL Server Configuration (if DB_TYPE=sqlserver)
SQLSERVER_SERVER=localhost\\SQLEXPRESS
SQLSERVER_DATABASE=mathgameapp
SQLSERVER_USER=
SQLSERVER_PASSWORD=
# Leave USER and PASSWORD empty to use Windows Authentication (-E flag)

# Session Configuration
SESSION_MAX_AGE=28800000
# 28800000 ms = 8 hours
